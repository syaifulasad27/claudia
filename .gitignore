# OpenClaw Agent - .gitignore

# Environment variables (sensitive)
.env
.env.local
.env.*.local

# OpenClaw runtime data
.openclaw/

# Session data (large files)
*.jsonl
sessions/

# Runtime logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (if using node scripts)
node_modules/

# MarketIntelligence runtime state/cache
MarketIntelligence/state/*.json
MarketIntelligence/state/*.md
MarketIntelligence/state/*.txt
!MarketIntelligence/state/.gitkeep

# Accidental relative output path guard
MarketIntelligence/memory/

# smart-search runtime state/cache
smart-search/state/*.json
smart-search/state/*.jsonl
!smart-search/state/.gitkeep

# Memory short-term state
memory/active-session-bias.md

# Backup files
*.bak
*.backup

prd.md
